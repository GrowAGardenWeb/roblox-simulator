<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Korblox Deathspeaker - Roblox</title>
<style>
:root{
  --surface-0:#111214;--surface-100:#191a1f;--surface-200:#202227;--surface-300:#272930;
  --shift-300:rgba(208,217,251,.12);
  --content-emphasis:#f7f7f8;--content-default:#d5d7dd;--content-muted:#9a9fb0;
  --stroke-default:rgba(208,217,251,.1);--stroke-emphasis:rgba(208,217,251,.18);
  --state-hover:rgba(208,217,251,.07);
  --blue-700:#335fff;
}
*{box-sizing:border-box;margin:0;padding:0}
body{
  font-family:'Builder Sans',system-ui,-apple-system,sans-serif;
  background:var(--surface-0);min-height:100vh;
  color:var(--content-emphasis);-webkit-font-smoothing:antialiased;
}

/* NAV */
.nav{
  height:52px;background:var(--surface-100);
  border-bottom:1px solid var(--stroke-default);
  display:flex;align-items:center;justify-content:space-between;
  padding:0 24px;position:sticky;top:0;z-index:50;
}
.nav-logo{
  font-family:'Builder Extended','Builder Sans',system-ui,sans-serif;
  font-size:20px;font-weight:700;color:var(--content-emphasis);letter-spacing:-0.5px;
}
.nav-right{display:flex;align-items:center;gap:16px}
.nav-bal{display:flex;align-items:center;gap:5px;font-size:14px;font-weight:600;color:var(--content-emphasis)}
.nav-bal img{width:16px;height:16px;object-fit:contain}
.cart-wrap{position:relative;cursor:pointer}
.cart-wrap svg{display:block}
.cart-badge{
  position:absolute;top:-5px;right:-6px;
  background:var(--blue-700);color:#fff;
  font-size:9px;font-weight:700;
  width:15px;height:15px;border-radius:50%;
  display:flex;align-items:center;justify-content:center;
}

/* PAGE LAYOUT */
.page{
  max-width:1100px;margin:0 auto;
  padding:32px 24px 60px;
  display:flex;gap:40px;
  align-items:flex-start;
}

/* LEFT COL */
.left-col{width:420px;flex-shrink:0;display:flex;flex-direction:column;gap:0}

.img-box{
  background:#1c1e24;
  border-radius:12px;
  overflow:hidden;
  aspect-ratio:1/1;
  display:flex;align-items:center;justify-content:center;
  position:relative;
}
.item-img{width:88%;height:88%;object-fit:contain;display:block}

.img-action-bar{
  position:absolute;bottom:12px;right:12px;
  display:flex;gap:8px;
}
.img-btn{
  background:rgba(30,32,38,.88);backdrop-filter:blur(4px);
  border:1px solid rgba(208,217,251,.15);border-radius:8px;
  padding:7px 14px;color:var(--content-emphasis);
  font-family:'Builder Sans',system-ui,sans-serif;font-size:13px;font-weight:600;
  cursor:pointer;transition:background .15s;
}
.img-btn:hover{background:rgba(50,53,62,.9)}

.fav-row{
  display:flex;align-items:center;gap:6px;
  padding:10px 4px 0;
  font-family:'Builder Sans',system-ui,sans-serif;font-size:14px;color:var(--content-muted);
  cursor:pointer;width:fit-content;
}
.fav-row:hover{color:var(--content-default)}

/* RIGHT COL */
.right-col{flex:1;min-width:0;padding-top:4px}

.item-title{
  font-family:'Builder Extended','Builder Sans',system-ui,sans-serif;
  font-size:32px;font-weight:700;color:var(--content-emphasis);
  letter-spacing:-0.7px;line-height:1.1;margin-bottom:8px;
}

.by-row{
  display:flex;align-items:center;gap:6px;
  font-size:14px;color:var(--content-muted);margin-bottom:20px;
}
.by-row a{color:var(--content-muted);text-decoration:none;font-weight:500}
.by-row a:hover{text-decoration:underline;color:var(--content-default)}
.verified-badge{width:18px;height:18px;object-fit:contain;flex-shrink:0;vertical-align:middle}

.divider{height:1px;background:var(--stroke-default);margin-bottom:20px}

/* price */
.price-row{
  display:flex;align-items:center;gap:16px;
  margin-bottom:16px;
}
.price-label{font-size:15px;color:var(--content-muted);font-weight:500}
.price-val{
  display:flex;align-items:center;gap:8px;
  font-family:'Builder Extended','Builder Sans',system-ui,sans-serif;
  font-size:24px;font-weight:700;color:var(--content-emphasis);letter-spacing:-0.4px;
}
.price-val img{width:22px;height:22px;object-fit:contain}

/* buttons */
.buy-btn{
  width:100%;background:var(--blue-700);color:#fff;border:none;border-radius:10px;
  padding:14px;font-family:'Builder Extended','Builder Sans',system-ui,sans-serif;
  font-size:17px;font-weight:700;cursor:pointer;letter-spacing:-0.2px;
  margin-bottom:9px;position:relative;overflow:hidden;
}
.buy-btn::before{content:'';position:absolute;inset:0;background:transparent;transition:background .1s}
.buy-btn:hover::before{background:rgba(255,255,255,.09)}
.buy-btn span{position:relative;z-index:1}

.cart-btn{
  width:100%;background:#fff;color:#1a1a1a;border:none;border-radius:10px;
  padding:14px;font-family:'Builder Extended','Builder Sans',system-ui,sans-serif;
  font-size:17px;font-weight:700;cursor:pointer;letter-spacing:-0.2px;
  margin-bottom:9px;transition:background .15s;
}
.cart-btn:hover{background:#e8e8e8}

.gift-btn{
  width:100%;background:var(--shift-300);color:var(--content-emphasis);border:none;border-radius:10px;
  padding:13px;font-family:'Builder Extended','Builder Sans',system-ui,sans-serif;
  font-size:17px;font-weight:700;cursor:pointer;letter-spacing:-0.2px;
  margin-bottom:22px;position:relative;overflow:hidden;
  display:flex;align-items:center;justify-content:center;gap:8px;
}
.gift-btn::before{content:'';position:absolute;inset:0;background:transparent;transition:background .1s}
.gift-btn:hover::before{background:var(--state-hover)}
.gift-btn svg,.gift-btn span{position:relative;z-index:1}

/* info table */
.info-table{display:flex;flex-direction:column;gap:14px}
.info-row{display:flex;align-items:flex-start;gap:20px}
.info-key{
  font-size:14px;color:var(--content-muted);font-weight:500;
  width:120px;flex-shrink:0;display:flex;align-items:center;gap:5px;padding-top:1px;
}
.info-val{font-size:14px;color:var(--content-emphasis);line-height:1.5}
.info-val.desc{color:var(--content-default)}
.iicon{
  width:14px;height:14px;border-radius:50%;
  border:1.5px solid var(--content-muted);
  display:inline-flex;align-items:center;justify-content:center;
  font-size:8px;color:var(--content-muted);cursor:help;font-weight:700;flex-shrink:0;
}

/* ── OVERLAY ── */
.overlay{position:fixed;inset:0;z-index:100;background:rgba(8,8,12,.8);display:none;align-items:center;justify-content:center}
.overlay.open{display:flex}
.modal{background:var(--surface-100);border-radius:16px;width:100%;max-width:460px;margin:16px;overflow:hidden;display:flex;flex-direction:column}
.modal-header{display:flex;align-items:center;justify-content:space-between;padding:20px 24px 14px}
.modal-title{font-family:'Builder Extended','Builder Sans',system-ui,sans-serif;font-size:18px;font-weight:700;color:var(--content-emphasis);letter-spacing:-0.3px;display:flex;align-items:center;gap:8px}
.close-btn{background:none;border:none;cursor:pointer;color:var(--content-muted);padding:4px;border-radius:6px;display:flex;transition:background .1s}
.close-btn:hover{background:var(--shift-300)}
.screen{display:none;flex-direction:column}
.screen.active{display:flex}

/* search */
.modal-search{padding:0 24px 14px}
.search-input{width:100%;background:var(--surface-200);border:1.5px solid var(--stroke-default);border-radius:10px;padding:12px 16px;color:var(--content-emphasis);font-family:'Builder Sans',system-ui,sans-serif;font-size:15px;outline:none;transition:border-color .15s}
.search-input::placeholder{color:var(--content-muted)}
.search-input:focus{border-color:var(--blue-700)}
.search-result{margin-top:6px;background:var(--surface-200);border:1px solid var(--stroke-default);border-radius:10px;overflow:hidden;display:none}
.search-result.visible{display:block}
.result-row{display:flex;align-items:center;gap:12px;padding:12px 16px;cursor:pointer;transition:background .1s}
.result-row:hover{background:var(--state-hover)}
.result-avatar{width:40px;height:40px;border-radius:50%;overflow:hidden;flex-shrink:0;background:var(--surface-300)}
.result-avatar img{width:40px;height:40px;object-fit:cover;display:block}
.result-name{font-family:'Builder Sans',system-ui,sans-serif;font-size:15px;font-weight:600;color:var(--content-emphasis)}
.result-loading{padding:12px 16px;font-size:14px;color:var(--content-muted);display:none;font-family:'Builder Sans',system-ui,sans-serif}
.search-hint{padding:0 24px 20px;font-size:13px;color:var(--content-muted);text-align:center;font-family:'Builder Sans',system-ui,sans-serif}

/* gift confirm */
.gc-body{padding:16px 24px;display:flex;flex-direction:column;gap:12px}
.gc-user-row{display:flex;align-items:center;gap:12px;background:var(--surface-200);border-radius:12px;padding:14px 16px}
.gc-av{width:48px;height:48px;border-radius:50%;overflow:hidden;flex-shrink:0;background:var(--surface-300)}
.gc-av img{width:48px;height:48px;object-fit:cover;display:block}
.gc-uname{font-family:'Builder Extended','Builder Sans',system-ui,sans-serif;font-size:17px;font-weight:700;color:var(--content-emphasis)}
.gc-item-row{display:flex;align-items:center;gap:14px;background:var(--surface-200);border-radius:12px;padding:14px 16px}
.gc-item-img{width:68px;height:68px;object-fit:contain;border-radius:8px;flex-shrink:0;background:#1c1e24}
.gc-item-name{font-family:'Builder Extended','Builder Sans',system-ui,sans-serif;font-size:15px;font-weight:700;color:var(--content-emphasis);line-height:1.3}
.gc-item-price{font-size:13px;color:var(--content-muted);margin-top:4px;display:flex;align-items:center;gap:4px}
.gc-item-price img{width:13px;height:13px;object-fit:contain}
.gc-footer{padding:4px 24px 20px;display:flex;gap:10px}
.gc-btn{flex:1;border:none;border-radius:10px;padding:13px;font-family:'Builder Extended','Builder Sans',system-ui,sans-serif;font-size:16px;font-weight:700;cursor:pointer;position:relative;overflow:hidden;letter-spacing:-0.1px}
.gc-btn::before{content:'';position:absolute;inset:0;background:transparent;transition:background .1s;border-radius:inherit}
.gc-btn:hover::before{background:rgba(255,255,255,.07)}
.gc-btn span{position:relative;z-index:1}
.gc-gift{background:var(--blue-700);color:#fff}
.gc-cancel{background:var(--surface-300);color:var(--content-emphasis)}
.gc-cancel:hover::before{background:var(--state-hover)}

/* TOAST */
#toast{
  position:fixed;top:-90px;left:50%;transform:translateX(-50%);z-index:999;
  background:var(--surface-200);color:var(--content-emphasis);
  font-family:'Builder Sans',system-ui,sans-serif;font-size:14px;font-weight:600;
  padding:10px 18px 10px 10px;border-radius:12px;
  display:flex;align-items:center;gap:10px;
  border:1px solid var(--stroke-emphasis);
  transition:top .35s cubic-bezier(.2,0,0,1);
  box-shadow:0 6px 28px rgba(0,0,0,.55);
  white-space:nowrap;
}
#toast.show{top:16px}
.toast-img{width:38px;height:38px;object-fit:contain;border-radius:7px;background:#1c1e24;flex-shrink:0}
</style>
</head>
