    img: 'https://tr.rbxcdn.com/180DAY-ad5e4e841e5010042334ad1a6c1d08c0/420/420/Hat/Webp/noFilter',
    price: '33,999',
    tradable: 'Yes',
    holdingPeriod: 'Yes',
    type: 'Head Accessories',
    placement: 'Accessories | Head',
    materials: 'Basic',
    created: 'Jul 08, 2022',
    desc: 'Perfect for sending adventurers out to save the princess.',
    favs: '395.2K'
  }
};
let currentItem = ITEMS.korblox;

function applyItem(key){
  const item = ITEMS[key];
  currentItem = item;
  document.querySelector('.item-img').src = item.img;
  document.querySelector('.item-title').textContent = item.name;
  document.querySelector('.price-val').innerHTML = `<img src="https://cdn3.emoji.gg/emojis/6588_robux.png" alt=""> ${item.price}`;
  // favs
  const favRow = document.querySelector('.fav-row');
  if(favRow) favRow.innerHTML = `<svg width="17" height="17" viewBox="0 0 18 18" fill="none"><path d="M9 15.5S2 11 2 6a4 4 0 017-2.65A4 4 0 0116 6c0 5-7 9.5-7 9.5z" stroke="#9a9fb0" stroke-width="1.5"/></svg>${item.favs||'3.1M'}`;
  // rebuild info table
  const table = document.querySelector('.info-table');
  const rows = [
    ['Tradable', item.tradable],
    item.holdingPeriod ? ['Holding Period', item.holdingPeriod] : null,
    ['Type <span class="iicon">i</span>', item.type],
    ['Placement', item.placement],
    ['Materials <span class="iicon">i</span>', item.materials],
    ['Created', item.created],
    ['Description', item.desc, 'desc']
  ].filter(Boolean);
  table.innerHTML = rows.map(([k,v,cls])=>`<div class="info-row"><span class="info-key">${k}</span><span class="info-val${cls?' '+cls:''}">${v}</span></div>`).join('');
  // gift confirm
  document.querySelector('.gc-item-img').src = item.img;
  document.querySelector('.gc-item-name').textContent = item.name;
  document.querySelector('.gc-item-price').innerHTML = `<img src="https://cdn3.emoji.gg/emojis/6588_robux.png" alt="">${item.price}`;
  document.querySelector('.toast-img').src = item.img;
  document.querySelectorAll('.mp-item-opt').forEach(o=>o.classList.toggle('active', o.dataset.item===key));
}

document.getElementById('giftBtn').addEventListener('click',()=>{
  overlay.classList.remove('open');reset();
  document.getElementById('toastText').textContent=currentItem.name+' sent to '+selectedUser.name;
  document.querySelector('.toast-img').src=currentItem.img;
  const t=document.getElementById('toast');
  t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'),4000);
});
</script>

