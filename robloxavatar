.mp-header{display:flex;align-items:center;justify-content:space-between;padding:14px 16px 10px;border-bottom:1px solid rgba(208,217,251,.09)}
.mp-title{font-family:'Builder Extended','Builder Sans',system-ui,sans-serif;font-size:15px;font-weight:700;color:#f7f7f8}
.mp-close{background:none;border:none;cursor:pointer;padding:3px;border-radius:5px;display:flex;color:#bcbec8;transition:background .1s}
.mp-close:hover{background:rgba(208,217,251,.1)}
.mp-section{padding:12px 16px 14px}
.mp-section-label{font-family:'Builder Sans',system-ui,sans-serif;font-size:10px;font-weight:700;color:#bcbec8;letter-spacing:.5px;text-transform:uppercase;margin-bottom:9px}
.mp-row{display:flex;gap:7px}
.mp-input{flex:1;background:#202227;border:1.5px solid rgba(208,217,251,.12);border-radius:7px;padding:8px 11px;color:#f7f7f8;font-family:'Builder Sans',system-ui,sans-serif;font-size:13px;outline:none;transition:border-color .15s}
.mp-input::placeholder{color:#6a6f81}
.mp-input:focus{border-color:#335fff}
.mp-apply{background:#335fff;color:#fff;border:none;border-radius:7px;padding:8px 12px;font-family:'Builder Sans',system-ui,sans-serif;font-size:13px;font-weight:700;cursor:pointer;white-space:nowrap;transition:opacity .15s}
.mp-apply:hover{opacity:.85}
.mp-quick-row{display:flex;gap:5px;margin-top:7px;flex-wrap:wrap}
.mp-quick{background:#202227;border:1px solid rgba(208,217,251,.12);border-radius:6px;padding:5px 9px;color:#d5d7dd;font-family:'Builder Sans',system-ui,sans-serif;font-size:11px;font-weight:600;cursor:pointer;transition:background .1s}
.mp-quick:hover{background:#272930;border-color:rgba(208,217,251,.25)}
.mp-divider-line{height:1px;background:rgba(208,217,251,.09);margin:0 16px}
.mp-items-grid{display:flex;gap:7px;flex-wrap:wrap}
.mp-item-opt{
  flex:1;min-width:72px;
  background:#202227;border:2px solid transparent;
  border-radius:9px;overflow:hidden;cursor:pointer;
  display:flex;flex-direction:column;align-items:center;
  transition:border-color .15s;
}
.mp-item-opt:hover{border-color:rgba(208,217,251,.25)}
.mp-item-opt.active{border-color:#335fff}
.mp-item-opt img{width:100%;height:64px;object-fit:contain;background:#1c1e24;display:block}
.mp-item-opt span{font-family:'Builder Sans',system-ui,sans-serif;font-size:10px;font-weight:700;color:#d5d7dd;padding:5px 4px;text-align:center;display:block;line-height:1.2}

</style>

<script>
document.querySelectorAll('.mp-quick').forEach(b=>{
  b.addEventListener('click',()=>{ document.getElementById('rbxInput').value=b.dataset.v; });
});
document.getElementById('rbxApply').addEventListener('click',()=>{
  const val=parseInt(document.getElementById('rbxInput').value);
  if(isNaN(val)||val<0) return;
  const display=val>=1000000?(val/1000000).toFixed(1)+'M':val>=1000?Math.floor(val/1000)+'K':val.toString();
  // update nav balance
  const navBal=document.querySelector('.nav-bal');
  if(navBal){
    const img=navBal.querySelector('img');
    navBal.textContent=' '+display;
    if(img) navBal.prepend(img);
  }
  // toast
  const t=document.getElementById('toast');
  document.getElementById('toastText').textContent='Balance updated to '+display+' Robux';
  t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'),3000);
  document.getElementById('modPanel').classList.remove('open');
});
</script>

