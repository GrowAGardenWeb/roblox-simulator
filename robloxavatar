<style>
#modBtn{position:fixed;bottom:20px;right:20px;z-index:200;background:#272930;border:1px solid rgba(208,217,251,.2);border-radius:10px;padding:10px 15px;color:#f7f7f8;font-family:'Builder Sans',system-ui,sans-serif;font-size:12px;font-weight:700;letter-spacing:.4px;cursor:pointer;display:flex;align-items:center;gap:7px;box-shadow:0 4px 20px rgba(0,0,0,.5);transition:background .15s}
#modBtn:hover{background:#353741}
#modPanel{position:fixed;bottom:64px;right:20px;z-index:199;background:#191a1f;border:1px solid rgba(208,217,251,.14);border-radius:14px;width:300px;box-shadow:0 8px 36px rgba(0,0,0,.65);overflow:hidden;display:none;flex-direction:column}
