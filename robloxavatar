<script>
const overlay=document.getElementById('overlay');
const searchInput=document.getElementById('searchInput');
const searchResult=document.getElementById('searchResult');
const resultRow=document.getElementById('resultRow');
const resultAvatar=document.getElementById('resultAvatar');
const resultName=document.getElementById('resultName');
const resultLoading=document.getElementById('resultLoading');
let selectedUser={name:'',avatar:''};

function showScreen(id){document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));document.getElementById(id).classList.add('active')}
function reset(){searchInput.value='';searchResult.classList.remove('visible');resultLoading.style.display='none';showScreen('s1')}

document.getElementById('openGift').addEventListener('click',()=>{overlay.classList.add('open');reset()});
document.getElementById('closeModal').addEventListener('click',()=>{overlay.classList.remove('open');reset()});
overlay.addEventListener('click',e=>{if(e.target===overlay){overlay.classList.remove('open');reset()}});

let db;
searchInput.addEventListener('input',()=>{
  const q=searchInput.value.trim();
  searchResult.classList.remove('visible');
  resultLoading.style.display='none';
  clearTimeout(db);
  if(!q) return;
  resultLoading.style.display='block';
  db=setTimeout(async()=>{
    resultLoading.style.display='none';
    if(searchInput.value.trim()!==q) return;
    try{
      const res=await fetch(`https://roblox-proxy.moneyscriptsoficial.workers.dev/?q=${encodeURIComponent(q)}`);
      const data=await res.json();
      if(searchInput.value.trim()!==q) return;
      if(data.name&&data.avatar){
        resultName.textContent=data.name;
        resultRow.dataset.uname=data.name;
        resultRow.dataset.uavatar=data.avatar;
        resultAvatar.src=data.avatar;
        searchResult.classList.add('visible');
      }
    }catch(e){}
  },400);
});

resultRow.addEventListener('click',()=>{
  selectedUser.name=resultRow.dataset.uname||'';
  selectedUser.avatar=resultRow.dataset.uavatar||'';
  document.getElementById('gcAv').src=selectedUser.avatar;
  document.getElementById('gcName').textContent=selectedUser.name;
  showScreen('s2');
});

document.getElementById('cancelBtn').addEventListener('click',()=>{overlay.classList.remove('open');reset()});


